{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "agents/USAGE.md"
  ],
  "mcp": {
    "tidewave": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-proxy-wrapper",
        "TIDEWAVE_MCP_ENDPOINT"
      ]
    }
  }
  "lsp": { "elixir": {"disabled": true} }
}
